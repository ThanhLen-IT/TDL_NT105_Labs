# --- MATLAB Tạm thời & Cache ---
*.asv              # Autosave files (cực kỳ nên chặn)
*.m~               # Backup files
*.slxc             # Simulink cache
*.mex* # Compiled MEX files (phụ thuộc vào hệ điều hành)
node_modules/      # Nếu dùng app designer hoặc javascript
derived/           # Thư mục chứa dữ liệu phát sinh

# --- MATLAB Projects ---
resources/         # File hệ thống của MATLAB Project (thường sinh ra tự động)
_out/              # Thư mục output
work/              # Thư mục làm việc tạm thời

# --- Simulink ---
slprj/             # Thư mục mô phỏng của Simulink (rất nặng và sinh tự động)
*.tmp              # Files tạm
*.log              # Nhật ký chạy

# --- Hệ điều hành & IDE ---
.DS_Store          # macOS
Thumbs.db          # Windows
.vscode/           # Nếu bạn dùng VS Code để viết code MATLAB
.idea/             # Nếu dùng IntelliJ/PyCharm
